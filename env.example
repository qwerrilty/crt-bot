# ── Supabase ──────────────────────────────────────────────────────────────────
# Settings > API in your Supabase project dashboard
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # use service_role key (not anon)

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather
TELEGRAM_BOT_TOKEN=123456789:AAF...

# Random string you choose — added to webhook URL for security
TELEGRAM_WEBHOOK_SECRET=your_random_secret_here

# ── Scanner ───────────────────────────────────────────────────────────────────
# 24h USDT volume floor as MC proxy ($100K MC ≈ $10K/day vol)
MIN_MC_VOLUME_PROXY=10000

# ── Vercel ────────────────────────────────────────────────────────────────────
# Auto-generated by Vercel for cron auth — set this in Vercel dashboard too
CRON_SECRET=vercel_auto_generates_this
